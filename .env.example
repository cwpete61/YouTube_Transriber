# Database
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/knowledge_archive
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=knowledge_archive

# Redis
REDIS_URL=redis://localhost:6379

# Auth
AUTH_SECRET=your-secret-here # Generated with: openssl rand -base64 32
AUTH_URL=http://localhost:3000

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=password
EMAIL_FROM=noreply@example.com

# AI Services
OPENAI_API_KEY=
GEMINI_API_KEY=

# Storage (S3 / MinIO)
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
STORAGE_BUCKET=knowledge-archive
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000

# Models
EMBEDDING_MODEL=text-embedding-3-small
TRANSCRIPTION_MODEL=whisper-1

# Security
RATE_LIMIT_AUTH_WINDOW=15m
RATE_LIMIT_AUTH_MAX=5
